country_event = {
	id = kuomintangcomgress.200
	
	is_triggered_only = yes
	hidden = yes

	immediate = {
		
		if = {
			limit = {
				has_country_flag = {
					flag = KMT_SOC
					value > 3
				}
			}
			limit = {
				has_country_flag = {
					flag = KMT_RAD
					value > 3
				}
			}
			country_event = kuomintangcomgress.7
		}
		if = {
			limit = {
				has_country_flag = {
					flag = KMT_MOD
					value > 3
				}
			}
			country_event = kuomintangcomgress.8
		}
		if = {
			limit = {
				has_country_flag = {
					flag = KMT_CEN
					value > 3
				}
			}
			country_event = kuomintangcomgress.9
		}
		
		if = {
			limit = {
				has_country_flag = {
					flag = KMT_CCC
					value > 3
				}
			}
			country_event = kuomintangcomgress.10
		}
		
		
		
	}
}

country_event = {
    id = kuomintangcomgress.6
    title = "Zhou Enlai's Vicotry"
