						option = RULE_OPTION_KMT_CONGRES_BSS
					}
				}
		  }
		}
		name = "We Must Support Our True Cause"
		custom_effect_tooltip = ULE_KMT_tt
		hidden_effect = {
		modify_country_flag = {
			flag = KMT_RAD
			value = 1
